URxvt*font: xft:JetBrainsMono Nerd Font Mono:pixelsize=13.5:antialias=true
URxvt*scrollBar: false
URxvt*internalBorder: 20
URxvt.letterSpace: 1

URxvt*iso14755: false
URxvt*iso14755_52: false

URxvt.perl-ext-common: default,matcher,-confirm-paste

URxvt.url-launcher: /usr/bin/xdg-open
URxvt.matcher.button: 1

URxvt.keysym.Shift-Control-V: eval:paste_clipboard
URxvt.keysym.Shift-Control-C: eval:selection_to_clipboard


! base colors
*background: #151515
*foreground: #E8E3E3

! black
*color0:     #151515
*color8:     #424242

! pink
*color1:     #B66467
*color9:     #B66467

! green
*color2:     #8C977D
*color10:    #8C977D

! yellow
*color3:     #D9BC8C
*color11:    #D9BC8C

! purple
*color4:     #8DA3B9
*color12:    #8DA3B9

! pink
*color5:     #A988B0
*color13:    #A988B0

! blue
*color6:     #8AA6A2
*color14:    #8AA6A2

! white
*color7:     #E8E3E3
*color15:    #E8E3E3
